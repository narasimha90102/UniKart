{
  "name": "unikart-root",
  "version": "1.0.0",
  "scripts": {
    "install-all": "cd frontend && npm install && cd ../backend && npm install",
    "dev-frontend": "cd frontend && npm run dev",
    "dev-backend": "cd backend && npm run dev",
    "dev": "concurrently \"npm run dev-backend\" \"npm run dev-frontend\""
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "dependencies": {
    "resend": "^6.12.3"
  }
}
